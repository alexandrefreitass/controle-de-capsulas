modules = ["bash", "nodejs-20", "python-3.11", "python-3.12", "web"]
run = "cd backend && python manage.py migrate && python manage.py setup_dev_users && python manage.py runserver 0.0.0.0:8080"

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "cd backend && python manage.py migrate && python manage.py setup_dev_users && python manage.py runserver 0.0.0.0:8080"]

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 8080
externalPort = 80

[workflows]
runButton = "Frontend Development"

[[workflows.workflow]]
name = "Frontend Development"
author = 39906757
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm start"
